local MarketplaceService = game:GetService("MarketplaceService")
local HttpService = game:GetService("HttpService")

local remote = game:GetService("ReplicatedStorage"):WaitForChild("Assets"):WaitForChild("Remotes"):WaitForChild("RequestOwnedGamepasses")

local function getGamepasses()
	local passes = {}
	local cursor = ""

	repeat
		local url = "https://games.roproxy.com/v1/games/" .. game.GameId .. "/game-passes?limit=100&sortOrder=Asc&cursor=" .. cursor
		local ok, res = pcall(function()
			return HttpService:GetAsync(url)
		end)
		if not ok then break end

		local data = HttpService:JSONDecode(res)
		for _, pass in ipairs(data.data) do
			table.insert(passes, { id = pass.id, name = pass.name })
		end

		cursor = data.nextPageCursor or ""
	until cursor == ""

	return passes
end

local function getOwnedGamepasses(player)
	local owned = {}
	local passes = getGamepasses()

	for _, pass in ipairs(passes) do
		local owns = false
		pcall(function()
			owns = MarketplaceService:UserOwnsGamePassAsync(player.UserId, pass.id)
		end)
		if owns then
			owned[pass.name] = true
		end
	end

	return owned
end

remote.OnServerInvoke = function(player)
	local owned = getOwnedGamepasses(player)
	for name, value in pairs(owned) do
		print(name .. ": " .. tostring(value))
	end
end
